# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-build/
/.next-local-build/
/.next-prod/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# MCP config (contains secrets)
.mcp.json
.vscode/mcp.json

.vercel
.env*.local

# Claude Code memory / session files
.claude/

# Local Next.js dev build
/.next-local/

# Supabase temp files
supabase/.temp/

# User-uploaded exchange images (stored in Supabase storage in prod)
/public/uploads/exchange/

# Scratch notes
\# Code Citations.txt
