# External news API
GNEWS_API_KEY=your_gnews_api_key

# Supabase public project variables
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase server-side key (keep secret, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-3-5-sonnet-latest

# Resend (transactional email)
RESEND_API_KEY=re_your_resend_api_key
# Use a verified domain address in production; for testing, onboarding@resend.dev works with any To address
RESEND_FROM_EMAIL=EV Guide <you@yourdomain.com>

# Optional: bank loan department routing for admin forwarding
# BANK_LOAN_EMAIL_<BANK_NAME> uses uppercase with underscores, e.g. HSBC -> BANK_LOAN_EMAIL_HSBC
BANK_LOAN_EMAIL_HSBC=loans@hsbc.com
BANK_LOAN_EMAIL_SANTANDER=loans@santander.com
BANK_LOAN_EMAIL_LLOYDS=loans@lloyds.com
# Fallback if a specific bank email is not provided
DEFAULT_LOAN_DEPARTMENT_EMAIL=loans@yourdomain.com

# Optional: external brand inventory APIs used by Find My EV.
# Tesla has a built-in public inventory fallback if this is empty.
BYD_VEHICLE_API_URL=
TESLA_VEHICLE_API_URL=
OMODA_VEHICLE_API_URL=
